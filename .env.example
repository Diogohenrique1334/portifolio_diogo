# Copie este arquivo para `.env` e preencha os valores reais.
# O `.env` é ignorado pelo git — nunca comite segredos.

# Senha do painel admin (acesse em http://localhost:8501/Admin)
PORTFOLIO_ADMIN_PASSWORD=troque_por_uma_senha_forte

# --- Assistente da trajetória (RAG) ---
# Chave da OpenAI (embeddings + chat)
OPENAI_API_KEY=sk-...
# Postgres Neon (mesmo banco pode ser usado por outros projetos). Aceita URL
# libpq comum; sufixos de driver async (+asyncpg) são removidos automaticamente.
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/dbname?sslmode=require
# Modelos (opcional — sobrescreva conforme sua conta; ex.: gpt-5-mini como no Finanças)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Integração opcional com o banco do Diagnóstico (Neon) ---
# URL do banco do projeto Diagnóstico. Se vazio, a integração é ignorada.
DIAGNOSTICO_DATABASE_URL=
# Allowlist de empresas SEGURAS para exposição em DETALHE (acadêmico/hobby),
# separadas por vírgula. Tudo fora daqui (inclusive empresa desconhecida) vira só
# AGREGADO — dado profissional/Claro nunca é detalhado. Ex.:
# DIAGNOSTICO_EMPRESAS_DETALHE=Anhembi Morumbi,Pessoal
DIAGNOSTICO_EMPRESAS_DETALHE=
